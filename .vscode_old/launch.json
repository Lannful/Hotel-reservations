{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Uvicorn with Reload",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app", // Adjust this to your app's entry point
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "console": "integratedTerminal"
        }
    ]
}